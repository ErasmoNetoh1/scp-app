{
    "version": "0.2.0",
    "configurations": [
        {
            // roda a interface de linha de comando
            "type": "java",
            "name": "Rodar CLI (Terminal)",
            "request": "launch",
            "mainClass": "com.scpapp.MainCLI",
            "projectName": "scp-app",
            "console": "integratedTerminal" // obrigatório para o scanner funcionar, 
            // sem isso o programa não consegue ler a entrada do usuário no terminal 
        },
        {
            // roda a interface gráfica
            "type": "java",
            "name": "Rodar GUI (JavaFX)",
            "request": "launch",
            "mainClass": "com.scpapp.MainApp",
            "projectName": "scp-app",
            "vmArgs": "--module-path \"${env:PATH_TO_FX}\" --add-modules javafx.controls,javafx.fxml"
            // vmArgs passa argumentos direto para a JVM (máquina virtual Java).
        }
    ]
}