{
    "java.configuration.runtimes": [
        {
            "name": "JavaSE-21",
            "path": "/usr/lib/jvm/java-21-openjdk-amd64",
            "default": true
        }
    ],
    // Exclui pastas que não precisam ser monitoradas pelo VSCode
    "files.exclude": {
        "**/target": true,
        "**/.classpath": true,
        "**/.project": true,
        "**/.settings": true,
        "**/.factorypath": true
    },
    // Formata o código Java automaticamente ao salvar
    "editor.formatOnSave": true,
    // Mostra erros de Java em tempo real enquanto você digita
    "java.autobuild.enabled": true
}